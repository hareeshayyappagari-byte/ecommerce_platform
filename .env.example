# Environment Configuration - Copy to .env and fill with actual values
# DO NOT commit .env to version control

# ============================================================================
# SECRET KEY - Generate a new one for production
# ============================================================================
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-change-in-production

# ============================================================================
# DEBUG MODE - Set to False in production
# ============================================================================
DEBUG=False

# ============================================================================
# ALLOWED HOSTS - Your domain names (comma-separated for production)
# ============================================================================
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ============================================================================
# DATABASE CONFIGURATION - Optional PostgreSQL for production
# ============================================================================
# For production on Render: DATABASE_URL will be provided automatically
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yoursite.com

# ============================================================================
# SECURITY SETTINGS - Enable in production
# ============================================================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False

# ============================================================================
# STRIPE PAYMENT GATEWAY (Optional)
# ============================================================================
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# ============================================================================
# AWS S3 CONFIGURATION (Optional - for static/media files storage)
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
